<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaApplication1.ViewModels"
        x:Class="AvaloniaApplication1.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1000"
        Height="600"
        Title="АРМ работника склада"
        Background="White">

    <DockPanel Background="White">

        <Menu DockPanel.Dock="Top"
              Background="White"
              Foreground="Black">

            <MenuItem Header="_Файл" Foreground="Black">
                <MenuItem Header="Выход" Foreground="Black" Click="ExitMenuItem_Click"/>
            </MenuItem>

            <MenuItem Header="_Склад" Foreground="Black">
                <MenuItem Header="Добавить товар" Foreground="Black" Click="AddProduct_Click"/>
                <MenuItem Header="Редактировать товар" Foreground="Black" Click="EditProduct_Click"/>
                <MenuItem Header="Удалить товар" Foreground="Black" Click="DeleteProduct_Click"/>
            </MenuItem>

            <MenuItem Header="_Настройки" Foreground="Black">
                <MenuItem Header="Параметры" Foreground="Black" Click="Settings_Click"/>
            </MenuItem>
        </Menu>

        <!-- Панель кнопок -->
        <Border DockPanel.Dock="Top"
                Background="White"
                Padding="8"
                BorderBrush="LightGray"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="8">

                <Button Content="Добавить товар"
                        Click="AddProduct_Click"
                        MinWidth="140"/>

                <Button Content="Редактировать товар"
                        Click="EditProduct_Click"
                        MinWidth="160"/>

                <Button Content="Удалить товар"
                        Click="DeleteProduct_Click"
                        MinWidth="140"/>
            </StackPanel>
        </Border>

        <!-- Основное содержимое -->
        <Grid Margin="10"
              Background="White"
              RowDefinitions="Auto,*">

            <TextBlock Text="Список товаров на складе"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="Black"
                       Margin="0,0,0,10"/>

            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10">

                <ListBox ItemsSource="{Binding Products}"
                         SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                         Background="White"
                         Foreground="Black">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8" Margin="0,0,0,6" Background="White">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="Bold"
                                               Foreground="Black"/>
                                    <TextBlock Text="{Binding Quantity, StringFormat=Количество: {0}}"
                                               Foreground="Black"/>
                                    <TextBlock Text="{Binding Price, StringFormat=Цена: {0} ₽}"
                                               Foreground="Black"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

            </Border>
        </Grid>

    </DockPanel>
</Window>